NODE_ENV=production
PORT=5000

# Public frontend URL, for Stripe redirects and CORS.
FRONTEND_URL=https://your-frontend-service.up.railway.app
CORS_ORIGIN=https://your-frontend-service.up.railway.app

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_AVATAR_BUCKET=avatars

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key

# SmartAppoint AI service
AI_SERVICE_URL=https://your-ai-service.up.railway.app/predict/batch
# Optional single prediction endpoint. If omitted, it is derived from AI_SERVICE_URL.
# AI_PREDICT_URL=https://your-ai-service.up.railway.app/predict

# Rate limits
AUTH_RATE_LIMIT_MAX=40
ADMIN_RATE_LIMIT_MAX=120
